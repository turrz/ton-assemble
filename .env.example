# TonAssemble root environment
# Copy this file to .env and replace placeholders before running the API or bot.

# Telegram bot token from BotFather.
BOT_TOKEN=your_telegram_bot_token

# Public HTTPS origin for the API and Mini App.
PUBLIC_BASE_URL=https://your-public-app-url

# Optional path appended by the bot when opening the Mini App.
WEBAPP_PATH=

# Optional Telegram user id allowed to create one-time access keys with /key.
ADMIN_TELEGRAM_ID=

# SQLite database path shared by the API and bot.
DB_PATH=./data/tonassemble.sqlite

# API server port.
PORT=3000

# TON mainnet RPC configuration.
TON_RPC_URL=https://mainnet-v4.tonhubapi.com
TON_NETWORK=mainnet

# Publishing mode A: ADNL reverse proxy.
# Set this to a 64+ character ADNL hex value, or leave empty and configure TON Storage below.
TON_PROXY_ADNL_HEX=

# Publishing mode B: TON Storage.
# Required only when TON_PROXY_ADNL_HEX is empty.
TON_STORAGE_DAEMON_BIN=
TON_STORAGE_DAEMON_HOST=
TON_STORAGE_DB_PATH=

# Optional support page links.
DONATE_TON_ADDRESS=
DONATE_TEXT=
CONTACT_TELEGRAM=
CONTACT_X=
CONTACT_EMAIL=
